# Public hCaptcha site key shown in the browser.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# Server-side hCaptcha secret.
HCAPTCHA_SECRET_KEY=

# Resend configuration for the contact form API.
RESEND_API_KEY=
CONTACT_EMAIL_TO=support@hontosozo.com
RESEND_FROM_EMAIL=HONTO SOZO Contact <onboarding@resend.dev>

# Optional service redirects used by /go/[service].
SERVICE_URL_STUDY=
SERVICE_URL_HOUSING=
SERVICE_URL_CONSULTING=
